NODE_ENV=development
PORT=3001
SESSION_SECRET=replace-with-a-long-random-string

# Local database settings
DB_DIALECT=mysql
DB_NAME=tech_blog_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# SQLite option (useful for local testing)
# DB_DIALECT=sqlite
# DB_STORAGE=:memory:

# Optional hosted MySQL URL (JAWSDB or equivalent)
# JAWSDB_URL=mysql://username:password@hostname:3306/database_name

{
  "name": "tech-blog",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "NODE_ENV=development node index.js",
    "test": "NODE_ENV=test DB_DIALECT=sqlite DB_STORAGE=:memory: jest --runInBand",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all",
    "db:migrate:test": "DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:migrate --env test",
    "db:seed:test": "DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:seed:all --env test",
    "db:migrate:undo:test": "DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:migrate:undo:all --env test",
    "db:reset:test": "DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:migrate:undo:all --env test && DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:migrate --env test && DB_DIALECT=sqlite DB_STORAGE=./db/test.sqlite sequelize-cli db:seed:all --env test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coding-boot-camp/module-14-project-mvc.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/coding-boot-camp/module-14-project-mvc/issues"
  },
  "homepage": "https://github.com/coding-boot-camp/module-14-project-mvc#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-session-sequelize": "^8.0.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.22.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  }
}
